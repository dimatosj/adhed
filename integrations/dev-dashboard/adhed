# ---------------------------------------------------------------------------
# cmd_rules_create
# ---------------------------------------------------------------------------

cmd_rules_create() {
  require_config

  local name="${1:-}"
  [ -z "$name" ] && die "Usage: adhed rules create <name> --trigger TRIGGER --conditions-file FILE --actions-file FILE [--priority N]"
  shift

  local trigger="" conditions_file="" actions_file="" priority=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --trigger)         trigger="${2:-}";         shift 2 ;;
      --conditions-file) conditions_file="${2:-}"; shift 2 ;;
      --actions-file)    actions_file="${2:-}";    shift 2 ;;
      --priority)        priority="${2:-}";        shift 2 ;;
      *) die "Unknown flag: $1" ;;
    esac
  done

  [ -z "$trigger" ]         && die "--trigger is required"
  [ -z "$conditions_file" ] && die "--conditions-file is required"
  [ -z "$actions_file" ]    && die "--actions-file is required"
  [ -f "$conditions_file" ] || die "Conditions file not found: $conditions_file"
  [ -f "$actions_file" ]    || die "Actions file not found: $actions_file"

  local conditions actions
  conditions=$(cat "$conditions_file")
  actions=$(cat "$actions_file")

  local body
  body=$(jq -n \
    --arg name "$name" \
    --arg trigger "$trigger" \
    --argjson conditions "$conditions" \
    --argjson actions "$actions" \
    --arg priority "$priority" \
    '{
      name: $name,
      trigger: $trigger,
      conditions: $conditions,
      actions: $actions,
      priority: (if $priority != "" then ($priority | tonumber) else null end)
    } | with_entries(select(.value != null))')

  local resp
  resp=$(api_post "/api/v1/teams/${ADHED_TEAM_ID}/rules" "$body")
  check_errors "$resp"

  if $JSON_OUTPUT; then
    echo "$resp"
    return
  fi

  local id
  id=$(echo "$resp" | jq -r '.id')
  echo "Created rule: $id"
  echo "  Name: $(echo "$resp" | jq -r '.name')"
}

