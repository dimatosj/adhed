cmd_rules_update() {
  require_config

  local rule_id="${1:-}"
  [ -z "$rule_id" ] && die "Usage: adhed rules update <rule-id> [--enabled true|false] [--priority N]"
  shift

  local enabled="" priority=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --enabled)  enabled="${2:-}";  shift 2 ;;
      --priority) priority="${2:-}"; shift 2 ;;
      *) die "Unknown flag: $1" ;;
    esac
  done

  local body
  body=$(jq -n \
    --arg enabled "$enabled" \
    --arg priority "$priority" \
    '{
      enabled: (if $enabled != "" then ($enabled == "true") else null end),
      priority: (if $priority != "" then ($priority | tonumber) else null end)
    } | with_entries(select(.value != null))')

  local resp
  resp=$(api_patch "/api/v1/rules/${rule_id}" "$body")
  check_errors "$resp"

  if $JSON_OUTPUT; then
    echo "$resp"
    return
  fi

  echo "Updated rule: $rule_id"
}

