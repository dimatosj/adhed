#!/usr/bin/env bash
set -euo pipefail

VERSION="1.0.0"
CONFIG_FILE="$HOME/.config/dev-dashboard/config.json"

# Config values — populated by load_config() or env overrides
ADHED_URL="${ADHED_URL:-}"
ADHED_API_KEY="${ADHED_API_KEY:-}"
ADHED_TEAM_ID="${ADHED_TEAM_ID:-}"
ADHED_USER_ID="${ADHED_USER_ID:-}"
JSON_OUTPUT=false

# Remaining args after global flag parsing
REMAINING_ARGS=()

# ---------------------------------------------------------------------------
# Utilities
# ---------------------------------------------------------------------------

die() {
  echo "adhed: $*" >&2
  exit 1
}

load_config() {
  [ -f "$CONFIG_FILE" ] || return 0
  command -v jq &>/dev/null || return 0

  [ -z "$ADHED_URL" ]      && ADHED_URL=$(jq -r '.adhed_url // empty'      "$CONFIG_FILE" 2>/dev/null || true)
  [ -z "$ADHED_API_KEY" ]  && ADHED_API_KEY=$(jq -r '.adhed_api_key // empty'  "$CONFIG_FILE" 2>/dev/null || true)
  [ -z "$ADHED_TEAM_ID" ]  && ADHED_TEAM_ID=$(jq -r '.adhed_team_id // empty'  "$CONFIG_FILE" 2>/dev/null || true)
  [ -z "$ADHED_USER_ID" ]  && ADHED_USER_ID=$(jq -r '.adhed_user_id // empty'  "$CONFIG_FILE" 2>/dev/null || true)
}

require_config() {
  [ -z "$ADHED_URL" ]      && die "ADHED URL not configured (set adhed_url in $CONFIG_FILE or \$ADHED_URL)"
  [ -z "$ADHED_API_KEY" ]  && die "ADHED API key not configured (set adhed_api_key in $CONFIG_FILE or \$ADHED_API_KEY)"
  [ -z "$ADHED_TEAM_ID" ]  && die "ADHED team ID not configured (set adhed_team_id in $CONFIG_FILE or \$ADHED_TEAM_ID)"
  [ -z "$ADHED_USER_ID" ]  && die "ADHED user ID not configured (set adhed_user_id in $CONFIG_FILE or \$ADHED_USER_ID)"
}

# ---------------------------------------------------------------------------
# Global flag parsing
# ---------------------------------------------------------------------------

parse_global_flags() {
  REMAINING_ARGS=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --json)
        JSON_OUTPUT=true
        shift
        ;;
      --url)
        ADHED_URL="${2:-}"; shift 2
        ;;
      --api-key)
        ADHED_API_KEY="${2:-}"; shift 2
        ;;
      --team-id)
        ADHED_TEAM_ID="${2:-}"; shift 2
        ;;
      --user-id)
        ADHED_USER_ID="${2:-}"; shift 2
        ;;
      *)
        REMAINING_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

# ---------------------------------------------------------------------------
# HTTP helpers
# ---------------------------------------------------------------------------

# Internal: run curl and surface HTTP errors
_curl() {
  curl -sf \
    -H "X-API-Key: $ADHED_API_KEY" \
    -H "X-User-Id: $ADHED_USER_ID" \
    "$@"
}

api_get() {
  local path="$1"
  _curl "${ADHED_URL}${path}"
}

api_post() {
  local path="$1" body="$2"
  _curl -X POST \
    -H "Content-Type: application/json" \
    -d "$body" \
    "${ADHED_URL}${path}"
}

api_patch() {
  local path="$1" body="$2"
  _curl -X PATCH \
    -H "Content-Type: application/json" \
    -d "$body" \
    "${ADHED_URL}${path}"
}

api_delete() {
  local path="$1"
  _curl -X DELETE "${ADHED_URL}${path}"
}

check_errors() {
  local resp="$1"
  local detail
  detail=$(echo "$resp" | jq -r '.detail // empty' 2>/dev/null || true)
  if [ -n "$detail" ]; then
    die "API error: $detail"
  fi
}

# ---------------------------------------------------------------------------
# Resolution helpers
# ---------------------------------------------------------------------------

resolve_state() {
  local name="$1"
  require_config
  local resp
  resp=$(api_get "/api/v1/teams/${ADHED_TEAM_ID}/states")
  check_errors "$resp"
  local id
  id=$(echo "$resp" | jq -r --arg n "$name" '.[] | select(.name == $n) | .id' 2>/dev/null | head -1)
  [ -z "$id" ] && die "State not found: $name"
  echo "$id"
}

resolve_project() {
  local name="$1"
  require_config
  local resp
  resp=$(api_get "/api/v1/teams/${ADHED_TEAM_ID}/projects")
  check_errors "$resp"
  local id
  id=$(echo "$resp" | jq -r --arg n "$name" '.[] | select(.name == $n) | .id' 2>/dev/null | head -1)
  [ -z "$id" ] && die "Project not found: $name"
  echo "$id"
}

resolve_user() {
  local name="$1"
  require_config
  local resp
  resp=$(api_get "/api/v1/teams/${ADHED_TEAM_ID}/users")
  check_errors "$resp"
  local id
  id=$(echo "$resp" | jq -r --arg n "$name" '.[] | select(.name == $n or .email == $n) | .id' 2>/dev/null | head -1)
  [ -z "$id" ] && die "User not found: $name"
  echo "$id"
}

# ---------------------------------------------------------------------------
# cmd_health
# ---------------------------------------------------------------------------

cmd_health() {
  require_config
  local resp
  resp=$(curl -sf "${ADHED_URL}/api/v1/health" 2>/dev/null) || die "Could not reach ADHED at ${ADHED_URL}"
  check_errors "$resp"

  if $JSON_OUTPUT; then
    echo "$resp"
    return
  fi

  local status
  status=$(echo "$resp" | jq -r '.status // "ok"' 2>/dev/null || echo "ok")
  echo "ADHED is up — status: $status"
  echo "URL:     $ADHED_URL"
  echo "Team ID: $ADHED_TEAM_ID"
  echo "User ID: $ADHED_USER_ID"
}

# ---------------------------------------------------------------------------
# cmd_issues (dispatcher)
# ---------------------------------------------------------------------------

cmd_issues() {
  local subcmd="${1:-list}"
  shift || true

  case "$subcmd" in
    list)         cmd_issues_list "$@" ;;
    create)       cmd_issues_create "$@" ;;
    show)         cmd_issues_show "$@" ;;
    update)       cmd_issues_update "$@" ;;
    delete)       cmd_issues_delete "$@" ;;
    batch-create) cmd_issues_batch_create "$@" ;;
    batch-update) cmd_issues_batch_update "$@" ;;
    convert)      cmd_issues_convert "$@" ;;
    comment)      cmd_issues_comment "$@" ;;
    comments)     cmd_issues_comments "$@" ;;
    --help|-h)
      cat <<'EOF'
Usage: adhed issues <subcommand> [options]

Subcommands:
  list          List issues (default)
  create        Create a new issue
  show          Show issue details
  update        Update an issue
  delete        Delete an issue
  batch-create  Bulk create issues (JSON from stdin)
  batch-update  Bulk update issues (JSON from stdin)
  convert       Convert issue to project
  comment       Add a comment to an issue
  comments      List comments on an issue
EOF
      ;;
    *) die "Unknown issues subcommand: $subcmd" ;;
  esac
}

# ---------------------------------------------------------------------------
# cmd_issues_list
# ---------------------------------------------------------------------------

cmd_issues_list() {
  require_config

  local project="" state_type="" assignee="" priority_min="" priority_max=""
  local search="" limit="50" offset="0"

  while [ $# -gt 0 ]; do
    case "$1" in
      --project)     project="${2:-}";     shift 2 ;;
      --state-type)  state_type="${2:-}";  shift 2 ;;
      --assignee)    assignee="${2:-}";    shift 2 ;;
      --priority)    priority_min="${2:-}"; priority_max="${2:-}"; shift 2 ;;
      --priority-min) priority_min="${2:-}"; shift 2 ;;
      --priority-max) priority_max="${2:-}"; shift 2 ;;
      --search)      search="${2:-}";      shift 2 ;;
      --limit)       limit="${2:-}";       shift 2 ;;
      --offset)      offset="${2:-}";      shift 2 ;;
      *) die "Unknown flag: $1" ;;
    esac
  done

  # Build query string
  local qs=""
  append_qs() {
    local k="$1" v="$2"
    [ -z "$v" ] && return
    if [ -z "$qs" ]; then qs="?${k}=${v}"; else qs="${qs}&${k}=${v}"; fi
  }

  # Resolve project name to ID if given
  if [ -n "$project" ]; then
    project=$(resolve_project "$project")
  fi

  # Resolve assignee name to ID if given
  if [ -n "$assignee" ]; then
    local resolved_assignee
    resolved_assignee=$(resolve_user "$assignee" 2>/dev/null || echo "$assignee")
    assignee="$resolved_assignee"
  fi

  append_qs "project_id"   "$project"
  append_qs "state_type"   "$state_type"
  append_qs "assignee_id"  "$assignee"
  append_qs "priority_min" "$priority_min"
  append_qs "priority_max" "$priority_max"
  append_qs "search"       "$search"
  append_qs "limit"        "$limit"
  append_qs "offset"       "$offset"

  local resp
  resp=$(api_get "/api/v1/teams/${ADHED_TEAM_ID}/issues${qs}")
  check_errors "$resp"

  if $JSON_OUTPUT; then
    echo "$resp"
    return
  fi

  # Table output: ID (first 8), PRIORITY, TITLE, STATE, ASSIGNEE (first 8), DUE
  echo "$resp" | jq -r '
    ["ID", "PRIORITY", "TITLE", "STATE", "ASSIGNEE", "DUE"],
    (.[] | [
      (.id // "" | .[0:8]),
      (.priority // "" | tostring),
      (.title // "" | .[0:40]),
      (.state.name // ""),
      (.assignee.id // "" | .[0:8]),
      (.due_date // "")
    ])
    | @tsv
  ' | column -t -s $'\t'
}

# ---------------------------------------------------------------------------
# cmd_issues_create
# ---------------------------------------------------------------------------

cmd_issues_create() {
  require_config

  local title="" priority="" type="" project="" assignee="" description="" due_date=""

  # First positional arg is the title
  if [ $# -gt 0 ] && [[ "${1:-}" != --* ]]; then
    title="$1"
    shift
  fi

  while [ $# -gt 0 ]; do
    case "$1" in
      --priority)    priority="${2:-}";    shift 2 ;;
      --type)        type="${2:-}";        shift 2 ;;
      --project)     project="${2:-}";     shift 2 ;;
      --assignee)    assignee="${2:-}";    shift 2 ;;
      --description) description="${2:-}"; shift 2 ;;
      --due-date)    due_date="${2:-}";    shift 2 ;;
      --title)       title="${2:-}";       shift 2 ;;
      *) die "Unknown flag: $1" ;;
    esac
  done

  [ -z "$title" ] && die "Title is required (first positional arg or --title)"

  # Resolve project name to ID
  if [ -n "$project" ]; then
    project=$(resolve_project "$project")
  fi

  # Resolve assignee name to ID, fall back to value as-is
  if [ -n "$assignee" ]; then
    local resolved_assignee
    resolved_assignee=$(resolve_user "$assignee" 2>/dev/null || echo "$assignee")
    assignee="$resolved_assignee"
  fi

  # Build JSON body
  local body
  body=$(jq -n \
    --arg title "$title" \
    --arg priority "$priority" \
    --arg type "$type" \
    --arg project_id "$project" \
    --arg assignee_id "$assignee" \
    --arg description "$description" \
    --arg due_date "$due_date" \
    '{
      title: $title,
      priority: (if $priority != "" then ($priority | tonumber) else null end),
      type: (if $type != "" then $type else null end),
      project_id: (if $project_id != "" then $project_id else null end),
      assignee_id: (if $assignee_id != "" then $assignee_id else null end),
      description: (if $description != "" then $description else null end),
      due_date: (if $due_date != "" then $due_date else null end)
    } | with_entries(select(.value != null))')

  local resp
  resp=$(api_post "/api/v1/teams/${ADHED_TEAM_ID}/issues" "$body")
  check_errors "$resp"

  if $JSON_OUTPUT; then
    echo "$resp"
    return
  fi

  local id
  id=$(echo "$resp" | jq -r '.id')
  echo "Created issue: $id"
  echo "  Title: $(echo "$resp" | jq -r '.title')"
}

# ---------------------------------------------------------------------------
# cmd_issues_show
# ---------------------------------------------------------------------------

cmd_issues_show() {
  require_config

  local issue_id="${1:-}"
  [ -z "$issue_id" ] && die "Usage: adhed issues show <issue-id>"

  local resp
  resp=$(api_get "/api/v1/teams/${ADHED_TEAM_ID}/issues/${issue_id}")
  check_errors "$resp"

  if $JSON_OUTPUT; then
    echo "$resp"
    return
  fi

  echo "$resp" | jq -r '
    "ID:          " + (.id // ""),
    "Title:       " + (.title // ""),
    "Type:        " + (.type // ""),
    "Priority:    " + (.priority // "" | tostring),
    "State:       " + (.state.name // ""),
    "Assignee:    " + (.assignee.name // ""),
    "Project:     " + (.project.name // ""),
    "Due:         " + (.due_date // ""),
    "Created:     " + (.created_at // ""),
    "Description: " + (.description // "")
  '
}

# ---------------------------------------------------------------------------
# cmd_issues_update
# ---------------------------------------------------------------------------

cmd_issues_update() {
  require_config

  local issue_id="${1:-}"
  [ -z "$issue_id" ] && die "Usage: adhed issues update <issue-id> [flags]"
  shift

  local state="" priority="" assignee="" project="" due_date="" title="" description=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --state)       state="${2:-}";       shift 2 ;;
      --priority)    priority="${2:-}";    shift 2 ;;
      --assignee)    assignee="${2:-}";    shift 2 ;;
      --project)     project="${2:-}";     shift 2 ;;
      --due-date)    due_date="${2:-}";    shift 2 ;;
      --title)       title="${2:-}";       shift 2 ;;
      --description) description="${2:-}"; shift 2 ;;
      *) die "Unknown flag: $1" ;;
    esac
  done

  # Resolve state name to ID
  local state_id=""
  if [ -n "$state" ]; then
    state_id=$(resolve_state "$state")
  fi

  # Resolve project name to ID
  if [ -n "$project" ]; then
    project=$(resolve_project "$project")
  fi

  # Resolve assignee name to ID, fall back to value as-is
  if [ -n "$assignee" ]; then
    local resolved_assignee
    resolved_assignee=$(resolve_user "$assignee" 2>/dev/null || echo "$assignee")
    assignee="$resolved_assignee"
  fi

  local body
  body=$(jq -n \
    --arg state_id "$state_id" \
    --arg priority "$priority" \
    --arg assignee_id "$assignee" \
    --arg project_id "$project" \
    --arg due_date "$due_date" \
    --arg title "$title" \
    --arg description "$description" \
    '{
      state_id: (if $state_id != "" then $state_id else null end),
      priority: (if $priority != "" then ($priority | tonumber) else null end),
      assignee_id: (if $assignee_id != "" then $assignee_id else null end),
      project_id: (if $project_id != "" then $project_id else null end),
      due_date: (if $due_date != "" then $due_date else null end),
      title: (if $title != "" then $title else null end),
      description: (if $description != "" then $description else null end)
    } | with_entries(select(.value != null))')

  local resp
  resp=$(api_patch "/api/v1/teams/${ADHED_TEAM_ID}/issues/${issue_id}" "$body")
  check_errors "$resp"

  if $JSON_OUTPUT; then
    echo "$resp"
    return
  fi

  echo "Updated issue: $issue_id"
}

