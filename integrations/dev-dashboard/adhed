# ---------------------------------------------------------------------------
# cmd_fragments_create
# ---------------------------------------------------------------------------

cmd_fragments_create() {
  require_config

  local text="${1:-}"
  [ -z "$text" ] && die "Usage: adhed fragments create <text> --type TYPE [--summary TEXT] [--topics topic1,topic2]"
  shift

  local type="" summary="" topics_raw=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --type)    type="${2:-}";       shift 2 ;;
      --summary) summary="${2:-}";    shift 2 ;;
      --topics)  topics_raw="${2:-}"; shift 2 ;;
      *) die "Unknown flag: $1" ;;
    esac
  done

  [ -z "$type" ] && die "--type is required"

  # Convert comma-separated topics to JSON array
  local topics_json="[]"
  if [ -n "$topics_raw" ]; then
    topics_json=$(echo "$topics_raw" | jq -R 'split(",")')
  fi

  local body
  body=$(jq -n \
    --arg text "$text" \
    --arg type "$type" \
    --arg summary "$summary" \
    --argjson topics "$topics_json" \
    '{
      text: $text,
      type: $type,
      summary: (if $summary != "" then $summary else null end),
      topics: $topics
    } | with_entries(select(.value != null))')

  local resp
  resp=$(api_post "/api/v1/teams/${ADHED_TEAM_ID}/fragments" "$body")
  check_errors "$resp"

  if $JSON_OUTPUT; then
    echo "$resp"
    return
  fi

  local id
  id=$(echo "$resp" | jq -r '.id')
  echo "Created fragment: $id"
  echo "  Type: $(echo "$resp" | jq -r '.type')"
}

