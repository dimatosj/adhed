# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
  cat <<'USAGE'
adhed — CLI for ADHED issue tracker

Usage: adhed <command> [subcommand] [options]

Commands:
  health                          Check ADHED connection
  issues   list|create|show|update|delete|batch-create|batch-update|convert|comment|comments
  projects list|create|update
  labels   list|create|delete
  states   list|create
  rules    list|create|update|delete
  comments list|create
  audit                           View audit log
  notifications                   View notifications
  fragments list|create
  users    list
  teams    show|update
  summary                        Dashboard summary

Global flags:
  --json                          Output raw JSON
  --url URL                       Override ADHED URL
  --api-key KEY                   Override API key
  --team-id ID                    Override team ID
  --user-id ID                    Override user ID

Environment variables:
  ADHED_URL, ADHED_API_KEY, ADHED_TEAM_ID, ADHED_USER_ID

Config file: ~/.config/dev-dashboard/config.json
USAGE
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

load_config
parse_global_flags "$@"
set -- "${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}"

cmd="${1:-}"
shift || true

case "$cmd" in
  health)        cmd_health "$@" ;;
  issues)        cmd_issues "$@" ;;
  projects)      cmd_projects "$@" ;;
  labels)        cmd_labels "$@" ;;
  states)        cmd_states "$@" ;;
  rules)         cmd_rules "$@" ;;
  comments)      cmd_comments "$@" ;;
  audit)         cmd_audit "$@" ;;
  notifications) cmd_notifications "$@" ;;
  fragments)     cmd_fragments "$@" ;;
  users)         cmd_users "$@" ;;
  teams)         cmd_teams "$@" ;;
  summary)       cmd_summary "$@" ;;
  --help|-h|help) usage ;;
  --version|-v)  echo "adhed $VERSION" ;;
  "")            usage ;;
  *) die "Unknown command: $cmd. Run 'adhed --help' for usage." ;;
esac
