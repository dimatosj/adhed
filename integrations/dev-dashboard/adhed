      --entity-type) entity_type="${2:-}"; shift 2 ;;
      --entity-id)   entity_id="${2:-}";   shift 2 ;;
      --limit)       limit="${2:-}";       shift 2 ;;
      *) die "Unknown flag: $1" ;;
    esac
  done

  local qs=""
  append_audit_qs() {
    local k="$1" v="$2"
    [ -z "$v" ] && return
    if [ -z "$qs" ]; then qs="?${k}=${v}"; else qs="${qs}&${k}=${v}"; fi
  }

  append_audit_qs "entity_type" "$entity_type"
  append_audit_qs "entity_id"   "$entity_id"
  append_audit_qs "limit"       "$limit"

  local resp
  resp=$(api_get "/api/v1/teams/${ADHED_TEAM_ID}/audit${qs}")
  check_errors "$resp"

  if $JSON_OUTPUT; then
    echo "$resp"
    return
  fi

  echo "$resp" | jq -r '
    ["WHEN", "ACTION", "TYPE", "ENTITY", "USER"],
    (.[] | [
      (.created_at // "" | .[0:19]),
      (.action // ""),
      (.entity_type // ""),
      (.entity_id // "" | .[0:8]),
      (.user_id // "" | .[0:8])
    ])
    | @tsv
  ' | column -t -s $'\t'
}

