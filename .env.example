# ADHED Configuration
# Copy to .env and customize

# API port (default 8100)
# API_PORT=8100

# Database port exposed to host (default 5433)
# DB_PORT=5433

# Host interface to bind Postgres to. Default 127.0.0.1 (loopback
# only — safest). Set to 0.0.0.0 if you need to reach the DB from
# other machines on your network.
# DB_BIND=127.0.0.1

# Log level: debug, info, warning, error
# LOG_LEVEL=info

# Log format: plain (default) or json (structured, for log aggregation)
# LOG_FORMAT=plain
